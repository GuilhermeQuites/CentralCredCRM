    {
      "name": "Clientes",
      "item": [
        {
          "name": "Listar Clientes",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}clients?search=&per_page=15",
            "description": "Lista clientes. O parametro search busca por CPF ou nome."
          }
        },
        {
          "name": "Criar Cliente",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.id) pm.collectionVariables.set('client_id', data.id);",
                  "if (data.registrations && data.registrations[0] && data.registrations[0].id) {",
                  "  pm.collectionVariables.set('client_registration_id', data.registrations[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": {{user_id}},\n  \"name\": \"Cliente Postman\",\n  \"cpf\": \"98765432100\",\n  \"phone\": \"11988887777\",\n  \"email\": \"cliente.postman@email.com\",\n  \"birth_date\": \"1985-01-10\",\n  \"notes\": \"Criado via Postman\",\n  \"registration_count\": \"1\",\n  \"registrations\": [\"POSTMAN-001\"]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}clients",
            "description": "Cria cliente. Campos obrigatorios: user_id, name, cpf, phone, birth_date, registration_count e registrations. E-mail e notes sao opcionais."
          }
        },
        {
          "name": "Detalhar Cliente",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}clients/{{client_id}}",
            "description": "Retorna um cliente pelo ID."
          }
        },
        {
          "name": "Atualizar Cliente - PUT",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
