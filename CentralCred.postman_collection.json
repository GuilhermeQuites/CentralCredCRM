    {
      "key": "baseUrl",
      "value": "http://localhost:8000/api/",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "client_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "client_registration_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "contract_id",
      "value": "1",
