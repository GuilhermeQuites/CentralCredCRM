            "url": "{{baseUrl}}clients/{{client_id}}",
            "description": "Atualiza o cliente inteiro."
          }
        },
        {
          "name": "Atualizar Cliente - PATCH",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
