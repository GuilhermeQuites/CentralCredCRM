            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": {{user_id}},\n  \"name\": \"Cliente Postman Atualizado\",\n  \"cpf\": \"98765432100\",\n  \"phone\": \"11977776666\",\n  \"email\": \"cliente.atualizado@email.com\",\n  \"birth_date\": \"1985-01-10\",\n  \"notes\": \"Atualizado via PUT\",\n  \"registration_count\": \"1\",\n  \"registrations\": [\"POSTMAN-001\"]\n}",
              "options": {
                "raw": {
