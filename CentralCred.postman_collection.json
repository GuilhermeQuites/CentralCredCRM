{
  "info": {
    "_postman_id": "8f63b604-9432-46a5-a57b-56f6b76ac001",
    "name": "CentralCred API",
    "description": "Collection completa da API CentralCred. A rota base esta fixa em http://localhost:8000/api/.\n\nComo usar:\n1. Execute Autenticacao > Login.\n2. O token sera salvo automaticamente na variavel token.\n3. Use as variaveis client_id, contract_id, bank_id, agreement_id e user_id para rotas de detalhe, edicao e exclusao.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": []
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": []
      }
    }
  ],
